ern",points:["Injection, Broken Authentication, Sensitive Data Exposure","Insecure Deserialization, XXE, Broken Access Control","Cross-Site Scripting (XSS) dan Cross-Site Request Forgery (CSRF)","Demonstrasi langsung serangan dan mitigasi di kode"]},{title:"3. Secure Coding: Input Validation, Output Encoding, Error Handling",points:["Validasi input di semua lapisan (client, server, database)","Encoding output untuk mencegah XSS dan injection","Penanganan error tanpa membocorkan stack trace atau data internal","Defensive programming: assume hostile input"]},{title:"4. Autentikasi, Otorisasi & Manajemen Sesi",points:["Implementasi password hashing (bcrypt, Argon2) yang benar","JWT, OAuth 2.0, dan session management aman","Multi-factor authentication (MFA) di aplikasi Anda","Role-based access control (RBAC) dan principle of least privilege"]},{title:"5. Keamanan Data: Enkripsi, Hashing, Manajemen Secret",points:["Perbedaan enkripsi, hashing, dan encoding \u2014 kapan pakai yang mana","Penyimpanan secret yang aman (Vault, AWS Secrets Manager, .env)","Jangan pernah commit secret ke Git \u2014 cara membersihkan history","TLS, HTTPS, dan enkripsi data at-rest vs in-transit"]},{title:"6. Keamanan API & Supply Chain (Dependency Risk)",points:["Rate limiting, API key rotation, dan API gateway","Risiko dependency npm/pip/composer dan cara audit","Software Bill of Materials (SBOM) dan dependency scanning","Studi kasus log4shell dan event-stream \u2014 bagaimana mendeteksi lebih awal"]},{title:"7. AI Aman: Menggunakan ChatGPT/Claude/Copilot dengan Aman",points:["Apa yang TIDAK boleh ditempel ke prompt AI publik","Risiko prompt injection di aplikasi Anda yang memakai LLM","Self-hosted vs API komersial \u2014 pertimbangan keamanan data","Kebijakan AI yang sehat untuk tim engineering"]},{title:"8. AI untuk Keamanan: Code Review, Static Analysis, Threat Detection",points:["Memakai AI untuk code review otomatis dan deteksi kerentanan","Static Application Security Testing (SAST) berbantu AI","Anomali detection di log produksi dengan model AI","Workflow praktis: PR review + CI/CD + AI gate"]},{title:"9. Penanganan Insiden, Logging & Audit Trail",points:["Apa yang termasuk insiden keamanan dan klasifikasinya","Logging yang berguna vs logging yang membocorkan data","Incident response plan: siapa, kapan, bagaimana melapor","Kewajiban pelaporan dalam 72 jam menurut UU PDP/GDPR"]},{title:"10. Ujian Sertifikasi",points:["10\u201320 soal pilihan ganda mencakup seluruh materi pelatihan","Nilai minimal kelulusan: 80%","Sertifikat resmi diterbitkan untuk peserta yang lulus"]}],v=[{question:"Anda menerima input nama pengguna dan langsung memasukkannya ke query SQL. Apa risiko terbesarnya?",options:["Tidak ada \u2014 selama input divalidasi di frontend","SQL Injection \u2014 penyerang dapat menjalankan query berbahaya","Hanya masalah performa, bukan keamanan","Cukup escape karakter spasi saja"],correct:1},{question:"Tim Anda akan menggunakan Copilot untuk mempercepat coding. Mana praktik yang paling aman?",options:["Tempel seluruh codebase ke prompt agar AI paham konteks","Sertakan API key di komentar supaya saran AI lebih akurat","Jangan pernah tempel secret, data pelanggan, atau kode rahasia ke prompt AI publik","Matikan semua AI di tim \u2014 tidak ada cara aman"],correct:2},{question:"Anda secara tidak sengaja melakukan commit file .env berisi password database ke repo publik di GitHub. Tindakan pertama yang benar?",options:["Hapus file dari commit terakhir saja, password tetap aman","Anggap password sudah bocor \u2014 segera rotasi/ubah semua kredensial, lalu bersihkan history","Buat repo jadi private \u2014 tidak ada yang akan menemukan","Tunggu sampai ada yang melapor"],correct:1},{question:"Untuk menyimpan password pengguna di database, mana metode yang benar?",options:["Simpan dalam plain text agar mudah di-debug","Enkripsi dengan AES menggunakan kunci yang disimpan di kode","Hash dengan bcrypt atau Argon2 menggunakan salt unik per user","Encode dengan base64 \u2014 sudah cukup aman"],correct:2},{question:"Sebuah library npm yang Anda pakai mengumumkan kerentanan kritis (RCE). Apa langkah pertama?",options:["Tunggu sampai versi 2.0 dari library tersebut keluar","Hapus seluruh dependency npm dari proyek","Periksa apakah aplikasi Anda terdampak, lalu update segera ke versi yang sudah dipatch","Tidak perlu khawatir \u2014 kerentanan npm jarang dieksploitasi"],correct:2}];function w(){var e=(0,o.useState)({}),a=e[0],n=e[1],i=(0,o.useState)(!1),r=i[0],s=i[1],l=r?v.reduce((function(e,n,t){return e+(a[t]===n.correct?1:0)}),0):0;return(0,m.jsxs)("div",{children:[(0,m.jsx)("div",{className:"space-y-8",children:v.map((function(e,i){return(0,m.jsxs)("div",{className:"bg-gray-800 rounded-lg p-6 border border-gray-700",children:[(0,m.jsxs)("p",{className:"text-white font-semibold mb-4",children:[i+1,". ",e.question]}),(0,m.jsx)("div",{className:"space-y-3",children:e.options.map((function(s,l){var o="border-gray-600",d="bg-gray-800";return r?l===e.correct?(o="border-green-500",d="bg-green-500/10"):a[i]===l&&l!==e.correct&&(o="border-red-500",d="bg-red-500/10"):a[i]===l&&(o="border-prime-100",d="bg-prime-100/10"),(0,m.jsxs)("button",{onClick:function(){return e=i,a=l,void(r||n((function(n){return g(g({},n),{},(0,t.Z)({},e,a))})));var e,a},className:"w-full text-left p-4 rounded-lg border ".concat(o," ").concat(d," text-gray-300 hover:border-prime-100 transition-colors ").concat(r?"cursor-default":"cursor-pointer"),children:[(0,m.jsxs)("span",{className:"font-semibold text-gray-400 mr-3",children:[String.fromCharCode(65+l),"."]}),s]},l)}))})]},i)}))}),(0,m.jsx)("div",{className:"mt-8 text-center",children:r?(0,m.jsxs)("div",{className:"bg-gray-800 rounded-xl p-8 border border-gray-700",children:[(0,m.jsxs)("p",{className:"text-3xl font-bold text-white mb-2",children:[l," / ",v.length]}),(0,m.jsx)("p",{className:"text-gray-400 text-lg",children:l===v.length?"Sempurna! Anda siap mengikuti ujian sertifikasi.":l>=4?"Bagus sekali