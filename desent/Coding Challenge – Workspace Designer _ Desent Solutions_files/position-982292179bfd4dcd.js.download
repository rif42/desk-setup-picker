(self.webpackChunk_N_E=self.webpackChunk_N_E||[]).push([[6151],{79323:function(e,i,n){"use strict";n.d(i,{H:function(){return o},m7:function(){return a}});var t=n(27812),a=[{slug:"back-end-developer",title:"Back-end Developer",value:"0",type:"Full-time",location:"Remote",department:"Engineering",summary:"Design and build scalable APIs and backend services powering our web and mobile products.",description:"As a Back-end Developer at Desent Solutions you will own the server-side architecture for both in-house products and client projects. You will design RESTful APIs, manage cloud infrastructure on Firebase, and write clean, well-tested Python code with Django. You will collaborate closely with front-end and mobile developers to deliver reliable, performant systems.",requirements:["Strong proficiency in Python and Django","Experience designing and building RESTful APIs","Working knowledge of Firebase (Firestore, Auth, Cloud Functions)","Comfortable with Git-based workflows and code reviews","Familiarity with Docker and containerized deployments","Understanding of relational and NoSQL databases"],responsibilities:["Architect and implement backend services and APIs","Write automated tests and maintain CI/CD pipelines","Collaborate with front-end and mobile teams on API contracts","Monitor and optimize application performance","Participate in code reviews and technical planning"],niceToHave:["Experience with GraphQL or gRPC","Knowledge of AWS, GCP, or other cloud platforms","Familiarity with message queues (RabbitMQ, Redis)","Contributions to open-source projects"],benefits:["Work with an international team across Germany, Indonesia, and Romania","Mix of exciting in-house products and client projects","Fully remote work with flexible hours","Regular team retreats in Bali","Budget for learning and conferences"],technologies:["Django","Python","Firebase","Git","Docker","REST APIs"]},{slug:"front-end-developer",title:"Front End Developer",value:"1",type:"Full-time",location:"Remote",department:"Engineering",summary:"Craft beautiful, performant user interfaces with React and Next.js for web applications.",description:"As a Front End Developer you will turn designs into pixel-perfect, accessible interfaces. You will work within our Next.js and Tailwind CSS stack, implement interactive components, optimize Core Web Vitals, and ensure a seamless experience across devices. You will partner with designers and back-end engineers to ship features end to end.",requirements:["Strong skills in React and Next.js","Proficiency with Tailwind CSS and responsive design","Solid understanding of TypeScript and modern JavaScript","Experience with Git-based workflows","Eye for design fidelity and attention to detail","Understanding of web accessibility standards (WCAG)"],responsibilities:["Build and maintain reusable UI components in React","Implement responsive layouts matching design specs","Optimize performance and Core Web Vitals","Integrate front-end with REST and GraphQL APIs","Collaborate with designers during handoff and iteration"],niceToHave:["Experience with animation libraries (Framer Motion, GSAP)","Familiarity with headless CMS platforms (Storyblok, Sanity)","Knowledge of testing frameworks (Jest, Cypress)","Experience with SSR/SSG strategies in Next.js"],benefits:["Work with an international team across Germany, Indonesia, and Romania","Mix of exciting in-house products and client projects","Fully remote work with flexible hours","Regular team retreats in Bali","Budget for learning and conferences"],technologies:["React","Next.js","Tailwind CSS","TypeScript","Git"]},{slug:"full-stack-developer",title:"Full Stack Developer",value:"2",type:"Full-time",location:"Remote",department:"Engineering",summary:"Bridge front-end and back-end to deliver complete features from database to browser.",description:"As a Full Stack Developer you will work across the entire stack \u2014 building React front-ends, Django back-ends, and everything in between. You thrive on owning a feature from API design through deployment and enjoy switching contexts between client-facing UI and server-side logic. This role is ideal for generalists who love shipping complete products.",requirements:["Proficiency in both React/Next.js and Django/Python","Experience building and consuming RESTful APIs","Working knowledge of Firebase services","Comfortable with Git, CI/CD, and deployment pipelines","Ability to translate designs into functional, polished UIs","Strong debugging and problem-solving skills"],responsibilities:["Develop features end to end \u2014 front-end, API, and database","Design database schemas and API contracts","Write and maintain automated tests across the stack","Deploy and monitor applications in production","Mentor junior developers and review pull requests"],niceToHave:["Experience with mobile development (React Native, Flutter)","Knowledge of DevOps tooling (Docker, Kubernetes, Terraform)","Familiarity with real-time features (WebSockets, Firebase Realtime DB)","Interest in system design and architecture"],benefits:["Work with an international team across Germany, Indonesia, and Romania","Mix of exciting in-house products and client projects","Fully remote work with flexible hours","Regular team retreats in Bali","Budget for learning and conferences"],technologies:["React","Next.js","Django","Python","Firebase","Git"]},{slug:"user-interface-designer",title:"User Interface Designer",value:"3",type:"Full-time",location:"Remote",department:"Design",summary:"Shape the look and feel of our products through research-driven UI and interaction design.",description:"As a UI Designer at Desent Solutions you will own the visual identity and interaction patterns across our product portfolio. From early wireframes in Miro to high-fidelity prototypes in Figma, you will define how users experience our software. You will collaborate with developers to ensure designs are implemented faithfully and iterate based on user feedback.",requirements:["Expert-level proficiency in Figma","Experience with collaborative tools like Miro and FigJam","Strong understanding of UI/UX principles and design systems","Ability to create interactive prototypes","Excellent communication and presentation skills","Portfolio demonstrating web and/or mobile UI work"],responsibilities:["Design wireframes, mockups, and interactive prototypes","Build and maintain a shared design system and component library","Conduct user research and usability testing","Collaborate with developers during implementation","Iterate on designs based on analytics and feedback"],niceToHave:["Experience with Adobe Creative Suite (Photoshop, Illustrator)","Knowledge of motion design and micro-interactions","Familiarity with HTML/CSS for design handoff","Experience designing for both web and mobile platforms"],benefits:["Work with an international team across Germany, Indonesia, and Romania","Mix of exciting in-house products and client projects","Fully remote work with flexible hours","Regular team retreats in Bali","Budget for learning and conferences"],technologies:["Figma","Miro","Adobe Creative Suite","Prototyping"]},{slug:"mobile-developer-android",title:"Mobile Developer Android",value:"4",type:"Full-time",location:"Remote",department:"Engineering",summary:"Build native Android experiences with Kotlin and Jetpack Compose for our growing user base.",description:"As an Android Developer you will create polished, native mobile experiences using Kotlin and Jetpack Compose. You will work on both in-house products and client apps, integrating with REST APIs and Firebase services. You care deeply about smooth animations, offline support, and delivering a best-in-class mobile UX.",requirements:["Strong proficiency in Kotlin","Experience with Jetpack Compose and modern Android architecture (MVVM, MVI)","Familiarity with Android SDK, Gradle, and the Play Store release process","Experience integrating REST APIs and Firebase SDKs","Comfortable with Git-based workflows","Understanding of Material Design guidelines"],responsibilities:["Develop and maintain native Android applications","Implement pixel-perfect UIs with Jetpack Compose","Integrate with backend APIs and Firebase services","Write unit and UI tests for reliable releases","Collaborate with designers and backend engineers"],niceToHave:["Experience with Kotlin Multiplatform (KMP)","Knowledge of CI/CD for mobile (Fastlane, GitHub Actions)","Familiarity with offline-first architecture and Room DB","Published apps on the Google Play Store"],benefits:["Work with an international team across Germany, Indonesia, and Romania","Mix of exciting in-house products and client projects","Fully remote work with flexible hours","Regular team retreats in Bali","Budget for learning and conferences"],technologies:["Kotlin","Jetpack Compose","Android SDK","Git"]},{slug:"mobile-developer-ios",title:"Mobile Developer iOS",value:"5",type:"Full-time",location:"Remote",department:"Engineering",summary:"Craft delightful iOS apps with Swift and SwiftUI for a global audience.",description:"As an iOS Developer you will build beautiful, performant native apps using Swift and SwiftUI. You will own the full mobile lifecycle \u2014 from Xcode project setup through App Store submission \u2014 and work closely with designers and backend engineers. You care about clean architecture, smooth animations, and an exceptional user experience on every Apple device.",requirements:["Strong proficiency in Swift and SwiftUI","Experience with iOS SDK, UIKit, and Xcode tooling","Understanding of MVVM and other modern architecture patterns","Experience integrating REST APIs and Firebase SDKs","Comfortable with Git-based workflows","Familiarity with Apple Human Interface Guidelines"],responsibilities:["Develop and maintain native iOS applications","Build responsive, accessible UIs with SwiftUI","Integrate with backend APIs and push notification services","Write unit and UI tests using XCTest","Manage App Store submissions and release cycles"],niceToHave:["Experience with Combine or async/await concurrency","Knowledge of CI/CD for iOS (Fastlane, Xcode Cloud)","Familiarity with Core Data or SwiftData for persistence","Published apps on the App Store"],benefits:["Work with an international team across Germany, Indonesia, and Romania","Mix of exciting in-house products and client projects","Fully remote work with flexible hours","Regular team retreats in Bali","Budget for learning and conferences"],technologies:["Swift","SwiftUI","iOS SDK","Xcode","Git"]},{slug:"qa-engineer-jira",title:"QA Engineer (Jira)",value:"6",type:"Full-time",location:"Remote",department:"Quality Assurance",summary:"Ensure product quality through structured testing, bug tracking, and QA workflows in Jira.",description:"As a QA Engineer at Desent Solutions you will own the quality assurance process across our web and mobile products. You will design test plans, write detailed test cases, manage bugs in Jira, and work closely with developers to ship reliable software. You bring a sharp eye for detail, a systematic approach to testing, and strong communication skills to bridge the gap between development and product teams.",requirements:["Strong proficiency with Jira for bug tracking, sprint planning, and workflow management","Experience writing structured test cases (given/when/then or similar formats)","Solid understanding of the software development lifecycle and Agile/Scrum methodologies","Experience with API testing using tools like Postman or Insomnia","Ability to create clear, reproducible bug reports with severity and priority classification","Familiarity with test management tools (TestRail, Zephyr, or similar)"],responsibilities:["Create and maintain test plans, test cases, and test suites for new features and releases","Execute manual testing across web and mobile platforms","Report, track, and verify bugs in Jira with detailed reproduction steps","Collaborate with developers and product managers during sprint planning and grooming","Define and maintain QA workflows, labels, and board configurations in Jira"],niceToHave:["Experience with test automation frameworks (Selenium, Cypress, or Playwright)","Familiarity with CI/CD pipelines and how testing fits into them","Knowledge of performance testing tools (JMeter, k6)","ISTQB or similar QA certification"],benefits:["Work with an international team across Germany, Indonesia, and Romania","Mix of exciting in-house products and client projects","Fully remote work with flexible hours","Regular team retreats in Bali","Budget for learning and conferences"],technologies:["Jira","Confluence","TestRail","Selenium","Postman","Git"]},{slug:"customer-service-specialist",title:"Customer Service Specialist (monis.rent)",value:"7",type:"Full-time",location:"Dalung, Bali (Hybrid)",department:"Customer Service",summary:"Ensure outstanding customer experiences by handling inquiries, resolving issues, and guiding customers through the monis.rent rental process.",description:"As a Customer Service Specialist at monis.rent, you will play a crucial role in ensuring that our customers receive outstanding service and support. You will be responsible for handling various customer inquiries, providing assistance, resolving issues, and ensuring a seamless rental experience. Your exceptional communication and problem-solving skills will be essential in addressing customer concerns and maintaining high levels of customer satisfaction. monis.rent is a workspace equipment rental service based in Bali, offering high-quality equipment for remote workers including monitors, keyboards, mice, and more.",requirements:["High school diploma or equivalent; additional education or certification in customer service is a plus","Proven work experience in customer service or a related role, preferably in the rental industry","Excellent verbal and written communication skills, with the ability to convey complex information in a clear and concise manner","Strong problem-solving and decision-making abilities, with a customer-focused mindset","Empathy and patience in dealing with customers' concerns and complaints","Proficiency in using Google Workspace and other related tools","Ability to multitask, prioritize workload, and manage time effectively in a fast-paced environment","Flexibility to work in shifts, including weekends and holidays","Fluency in English and Bahasa Indonesia (additional languages is a plus) \u2014 Professional English is a MUST","Located in Dalung or its surrounding areas"],responsibilities:["Serve as the first point of contact for customers through various channels (phone, email, live chat, and social media) and provide timely and accurate responses","Address customer inquiries, concerns, and complaints professionally and empathetically, ensuring a positive customer experience","Assist customers in navigating the monis.rent platform, explaining rental processes, terms, and conditions, and guiding them through the rental selection and booking process","Provide product and service information to customers, including pricing, availability, delivery options, and return procedures","Resolve customer issues and complaints by investigating problems, identifying root causes, and implementing effective solutions in a timely manner","Maintain a comprehensive understanding of monis.rent's rental offerings, policies, and procedures to address customer queries accurately and efficiently","Collaborate closely with other departments, such as operations and logistics, to ensure smooth rental transactions and resolve any operational challenges","Identify opportunities for process improvements and contribute to the development of customer service policies and procedures","Strive to achieve individual and team targets for customer satisfaction, response time, and issue resolution"],niceToHave:["Experience using Booqable Software","A positive attitude, adaptability, and a willingness to learn and grow in a dynamic organization"],benefits:["Hybrid work setup in Dalung, Bali","Negotiable salary depending on experience and test week result","Hiring process: Interview - Pre-Test - Test Week - Offering letter"],technologies:["Google Workspace","Booqable","Live Chat","Social Media"]}],o=[].concat((0,t.Z)(a.map((function(e){return{value:e.value,label:"".concat(e.title," (").concat(e.type,")")}}))),[{value:"other",label:"Other (I want to apply for something else.)"}])},89753:function(e,i,n){"use strict";n.r(i),n.d(i,{__N_SSG:function(){return c},default:function(){return d}});var t=n(9008),a=n.n(t),o=n(41664),r=n.n(o),s=n(79323),l=n(85893),c=!0;function d(){return(0,l.jsxs)("div",{className:"bg-gray-900",children:[(0,l.jsxs)(a(),{children:[(0,l.jsx)("title",{children:"Open Positions | Desent Solutions"}),(0,l.jsx)("meta",{name:"description",content:"Explore open positions at Desent Solutions \u2014 engineering, design, and more. Fully remote, international team."},"description"),(0,l.jsx)("meta",{property:"og:title",content:"Open Positions | Desent Solutions"},"og_title"),(0,l.jsx)("meta",{property:"og:description",content:"Explore open positions at Desent Solutions \u2014 engineering, design, and more."},"og_description")]}),(0,l.jsx)("div",{className:"global-container pt-32 pb-20 px-4 sm:px-6 lg:pt-40 lg:px-8",children:(0,l.jsxs)("div",{className:"max-w-5xl mx-auto",children:[(0,l.jsxs)("div",{className:"text-center mb-12",children:[(0,l.jsx)("p",{className:"text-sm text-prime-100 font-medium tracking-wide uppercase mb-2",children:"Careers at Desent Solutions"}),(0,l.jsx)("h1",{className:"text-4xl font-bold text-white sm:text-5xl mb-4",children:"Open Positions"}),(0,l.jsx)("p",{className:"text-lg text-gray-300 max-w-2xl mx-auto",children:"Join our international team across Germany, Indonesia, and Romania. All positions are fully remote."})]}),(0,l.jsx)("div",{className:"grid gap-6 sm:grid-cols-2 lg:grid-cols-3",children:s.m7.map((function(e){return(0,l.jsxs)(r(),{href:"/